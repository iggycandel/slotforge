{
  "id": "promo.landscape_lobby_tile",
  "name": "Landscape Lobby Tile",
  "category": "promo",
  "version": 1,
  "sizes": [
    { "w": 800,  "h": 600,  "label": "800x600",   "format": "png" },
    { "w": 1600, "h": 1200, "label": "1600x1200", "format": "png" }
  ],
  "layers": [
    { "type": "asset", "slot": "background_base", "fit": "cover", "anchor": "middle-center" },
    { "type": "gradient", "from": "rgba(0,0,0,0.65)", "to": "transparent", "direction": "right", "start": 0.0 },
    { "type": "asset", "slot": "character.transparent", "fit": "contain", "anchor": "middle-right", "scale": 0.95, "padding": 30 },
    { "type": "asset", "slot": "logo", "fit": "contain", "anchor": "top-left", "scale": 0.45, "padding": 50 },
    { "type": "text", "value": "${gameName}", "font": { "family": "Inter", "weight": 900, "size": 64, "tracking": 1.2 }, "color": "#ffffff", "stroke": { "color": "rgba(0,0,0,0.5)", "width": 3 }, "anchor": "middle-left", "align": "left", "maxWidth": "55%" },
    { "type": "cta", "valueVar": "ctaText", "style": "pill", "font": { "family": "Inter", "weight": 800, "size": 22 }, "bg": { "var": "colorAccent" }, "fg": "#ffffff", "anchor": "bottom-left", "padding": [12, 28] }
  ],
  "vars": {
    "gameName":      { "source": "project.gameName", "override": true },
    "headline":      { "default": null, "override": true },
    "subhead":       { "default": null, "override": true },
    "ctaText":       { "default": "PLAY NOW", "options": ["PLAY NOW", "SPIN NOW", "TRY IT", "NEW SLOT", "LAUNCHING SOON", "none"] },
    "language":      { "default": "EN", "options": ["EN","ES","PT","DE","FR","IT","SV","JA"] },
    "colorMode":     { "default": "auto", "options": ["auto","light","dark"] },
    "layoutVariant": { "default": "A", "options": ["A","B","C"] }
  },
  "previewPath": "/marketing/previews/promo_landscape_lobby_tile.png"
}
