{
  "id": "promo.medium_banner_300x200",
  "name": "Medium Banner — 300×200",
  "category": "promo",
  "version": 1,
  "sizes": [
    { "w": 300, "h": 200, "label": "300x200", "format": "jpg" },
    { "w": 600, "h": 400, "label": "600x400", "format": "jpg" }
  ],
  "layers": [
    { "type": "asset", "slot": "background_base", "fit": "cover", "anchor": "middle-center" },
    { "type": "gradient", "from": "rgba(0,0,0,0.5)", "to": "transparent", "direction": "right", "start": 0.0 },
    { "type": "asset", "slot": "character.transparent",
      "fit": "contain", "anchor": "bottom-left", "scale": 1.0,
      "padding": [0, "52%", 0, 8] },
    { "type": "asset", "slot": "logo",
      "fit": "contain", "anchor": "middle-right", "scale": 1.0,
      "padding": [16, 12, 16, "52%"],
      "whenAlone": { "anchor": "middle-center", "scale": 0.9, "padding": ["10%", "6%", "10%", "6%"] } }
  ],
  "vars": {
    "gameName":      { "source": "project.gameName", "override": true },
    "headline":      { "default": null, "override": true },
    "subhead":       { "default": null, "override": true },
    "ctaText":       { "default": "none", "options": ["PLAY NOW", "SPIN NOW", "TRY IT", "NEW SLOT", "LAUNCHING SOON", "none"] },
    "language":      { "default": "EN", "options": ["EN","ES","PT","DE","FR","IT","SV","JA"] },
    "colorMode":     { "default": "auto", "options": ["auto","light","dark"] },
    "layoutVariant": { "default": "A", "options": ["A","B","C"] }
  },
  "previewPath": "/marketing/previews/promo_medium_banner_300x200.png"
}
