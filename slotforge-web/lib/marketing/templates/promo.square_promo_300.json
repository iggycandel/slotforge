{
  "id": "promo.square_promo_300",
  "name": "Small Square Promo",
  "category": "promo",
  "version": 1,
  "sizes": [
    { "w": 300, "h": 300, "label": "300x300", "format": "jpg" },
    { "w": 600, "h": 600, "label": "600x600", "format": "jpg" }
  ],
  "layers": [
    { "type": "asset", "slot": "background_base", "fit": "cover", "anchor": "middle-center" },
    { "type": "gradient", "from": "transparent", "to": "rgba(0,0,0,0.65)", "direction": "bottom", "start": 0.4 },
    { "type": "asset", "slot": "character.transparent", "fit": "contain", "anchor": "bottom-center", "scale": 0.85, "padding": 16 },
    { "type": "asset", "slot": "logo", "fit": "contain", "anchor": "top-center", "scale": 0.65, "padding": 18 },
    { "type": "text", "value": "${gameName}", "font": { "family": "Inter", "weight": 900, "size": 22, "tracking": 1.1 }, "color": "#ffffff", "stroke": { "color": "rgba(0,0,0,0.5)", "width": 2 }, "anchor": "bottom-center", "align": "center", "maxWidth": "88%" }
  ],
  "vars": {
    "gameName":      { "source": "project.gameName", "override": true },
    "headline":      { "default": null, "override": true },
    "subhead":       { "default": null, "override": true },
    "ctaText":       { "default": "none", "options": ["PLAY NOW", "SPIN NOW", "TRY IT", "NEW SLOT", "LAUNCHING SOON", "none"] },
    "language":      { "default": "EN", "options": ["EN","ES","PT","DE","FR","IT","SV","JA"] },
    "colorMode":     { "default": "auto", "options": ["auto","light","dark"] },
    "layoutVariant": { "default": "A", "options": ["A","B","C"] }
  },
  "previewPath": "/marketing/previews/promo_square_promo_300.png"
}
