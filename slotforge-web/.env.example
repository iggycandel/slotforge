# ─── Clerk (Auth) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Secret key — never expose to the browser
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint
# Register: POST /api/webhooks/stripe
# Events:   checkout.session.completed
#           customer.subscription.updated
#           customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — from Stripe Dashboard → Products
# Create two products (SlotForge Pro, SlotForge Studio) with monthly recurring prices
STRIPE_PRO_PRICE_ID=price_...
STRIPE_STUDIO_PRICE_ID=price_...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://slotforge.io
